<Window x:Class="変成将棋.Views.C対局画面"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:変成将棋.ViewModels"
        Title="変成将棋"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanMinimize"
        Background="#2D2D2D">
    <Window.DataContext>
        <vm:C対局VM/>
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="棋譜ボタン" TargetType="Button">
            <Setter Property="Background"  Value="#444"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#666"/>
            <Setter Property="Height"      Value="26"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>
        <!-- 持ち駒テンプレート（後手・先手共通） -->
        <DataTemplate x:Key="持ち駒テンプレート">
            <Border Width="36" Height="40" Margin="2" Cursor="Hand" CornerRadius="3">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#555"/>
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding 駒あり}"   Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Is選択中}" Value="True">
                                <Setter Property="Background" Value="#CC9900"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding クリック}"/>
                </Border.InputBindings>
                <TextBlock Text="{Binding 表示}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="MS Gothic" FontSize="15"
                           FontWeight="Bold" Foreground="White"/>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>

    <!-- メニューバー -->
    <Menu DockPanel.Dock="Top" Background="#3A3A3A">
        <Menu.Resources>
            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="#3A3A3A"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>
        </Menu.Resources>
        <MenuItem Header="対局">
            <MenuItem Header="盤面初期化" Command="{Binding 盤面初期化コマンド}"/>
            <Separator Background="#555"/>
            <MenuItem Header="対局者設定">

                <MenuItem Header="先手人間 ／ 後手人間"
                          Command="{Binding 先後人間コマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先後人間, Mode=OneWay}"/>
                <MenuItem Header="先手人間 ／ 後手CPU"
                          Command="{Binding 先人間後CPUコマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先人間後CPU, Mode=OneWay}"/>
                <MenuItem Header="先手CPU ／ 後手人間"
                          Command="{Binding 先CPU後人間コマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先CPU後人間, Mode=OneWay}"/>
                <MenuItem Header="先手CPU ／ 後手CPU"
                          Command="{Binding 先後CPUコマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先後CPU, Mode=OneWay}"/>
                <Separator Background="#555"/>
                <MenuItem Header="先手人間 ／ 後手AI"
                          Command="{Binding 先人間後AIコマンド}"
                          IsEnabled="{Binding AIモデル読み込み済み}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先人間後AI, Mode=OneWay}"/>
                <MenuItem Header="先手AI ／ 後手人間"
                          Command="{Binding 先AI後人間コマンド}"
                          IsEnabled="{Binding AIモデル読み込み済み}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先AI後人間, Mode=OneWay}"/>
                <Separator Background="#555"/>
                <MenuItem Header="先手AI ／ 後手CPU"
                          Command="{Binding 先AI後CPUコマンド}"
                          IsEnabled="{Binding AIモデル読み込み済み}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先AI後CPU, Mode=OneWay}"/>
                <MenuItem Header="先手CPU ／ 後手AI"
                          Command="{Binding 先CPU後AIコマンド}"
                          IsEnabled="{Binding AIモデル読み込み済み}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先CPU後AI, Mode=OneWay}"/>
                <Separator Background="#555"/>
                <MenuItem Header="先手人間 ／ 後手αβ"
                          Command="{Binding 先人間後αβコマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先人間後αβ, Mode=OneWay}"/>
                <MenuItem Header="先手αβ ／ 後手人間"
                          Command="{Binding 先αβ後人間コマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先αβ後人間, Mode=OneWay}"/>
                <Separator Background="#555"/>
                <MenuItem Header="先手αβ ／ 後手CPU"
                          Command="{Binding 先αβ後CPUコマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先αβ後CPU, Mode=OneWay}"/>
                <MenuItem Header="先手CPU ／ 後手αβ"
                          Command="{Binding 先CPU後αβコマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先CPU後αβ, Mode=OneWay}"/>
                <Separator Background="#555"/>
                <MenuItem Header="先手人間 ／ 後手評価関数"
                          Command="{Binding 先人間後評価コマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先人間後評価, Mode=OneWay}"/>
                <MenuItem Header="先手評価関数 ／ 後手人間"
                          Command="{Binding 先評価後人間コマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先評価後人間, Mode=OneWay}"/>
                <Separator Background="#555"/>
                <MenuItem Header="先手評価関数 ／ 後手CPU"
                          Command="{Binding 先評価後CPUコマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先評価後CPU, Mode=OneWay}"/>
                <MenuItem Header="先手CPU ／ 後手評価関数"
                          Command="{Binding 先CPU後評価コマンド}"
                          IsCheckable="True"
                          IsChecked="{Binding Mode先CPU後評価, Mode=OneWay}"/>
            </MenuItem>
            <Separator Background="#555"/>
            <MenuItem Header="AIモデルを読み込む..." Click="OnAIモデル読み込みClick"/>
        </MenuItem>
        <MenuItem Header="棋譜">
            <MenuItem Header="棋譜を保存..." Click="OnKifuSaveClick"/>
            <MenuItem Header="棋譜を開く..."  Click="OnKifuLoadClick"/>
        </MenuItem>
    </Menu>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 後手持ち駒 -->
        <StackPanel Grid.Column="0" Grid.Row="1" VerticalAlignment="Top" Margin="0,8,8,0">
            <TextBlock Text="後手" Foreground="White" FontSize="13"
                       HorizontalAlignment="Right" Margin="0,0,0,4"/>
            <ItemsControl ItemsSource="{Binding 後手持ち駒一覧}"
                          ItemTemplate="{StaticResource 持ち駒テンプレート}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <!-- 盤面エリア -->
        <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" VerticalAlignment="Center">

            <!-- 時間表示（盤の上） -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding 後手時間表示}"
                           Foreground="#AAAAAA" FontSize="11" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="1" Text="{Binding 先手時間表示}"
                           Foreground="#AAAAAA" FontSize="11" HorizontalAlignment="Right"/>
            </Grid>

            <!-- 列番号（９〜１） -->
            <ItemsControl ItemsSource="{Binding 列番号一覧}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" Columns="9"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Width="56"
                                   TextAlignment="Center"
                                   Foreground="#AAAAAA" FontSize="13"
                                   Margin="0,0,0,2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 盤面 + 段番号 -->
            <StackPanel Orientation="Horizontal">

                <!-- 盤面本体 -->
                <Border BorderBrush="#7A5C00" BorderThickness="2">
                    <ItemsControl ItemsSource="{Binding 升一覧}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="9" Columns="9"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="56" Height="60"
                                        BorderBrush="#7A5C00" BorderThickness="0.5"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#DEB887"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Is最終手}" Value="True">
                                                    <Setter Property="Background" Value="#B0D4F0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Is選択中}" Value="True">
                                                    <Setter Property="Background" Value="#FFD700"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Is移動候補}" Value="True">
                                                    <Setter Property="Background" Value="#90EE90"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding クリック}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="{Binding 表示文字}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="28"
                                               FontFamily="MS Gothic"
                                               FontWeight="Bold"
                                               Foreground="#1A0A00">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="{Binding 回転角度}"/>
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- 段番号（一〜九） -->
                <ItemsControl ItemsSource="{Binding 段番号一覧}" Margin="4,0,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="9" Columns="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Height="60"
                                       VerticalAlignment="Center"
                                       Foreground="#AAAAAA" FontSize="13"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </StackPanel>

        <!-- 先手持ち駒 -->
        <StackPanel Grid.Column="2" Grid.Row="1" VerticalAlignment="Bottom" Margin="8,0,0,8">
            <ItemsControl ItemsSource="{Binding 先手持ち駒一覧}"
                          ItemTemplate="{StaticResource 持ち駒テンプレート}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <TextBlock Text="先手" Foreground="White" FontSize="13"
                       HorizontalAlignment="Left" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 手番・勝者表示 -->
        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="3"
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <TextBlock Text="{Binding 手番表示}"
                       Foreground="White" FontSize="16" FontWeight="Bold"
                       Margin="0,0,16,0"/>
            <TextBlock Text="{Binding 勝者表示}"
                       Foreground="#FFD700" FontSize="18" FontWeight="Bold"/>
        </StackPanel>

        <!-- 棋譜ナビゲーションバー -->
        <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="4"
                Background="#222" CornerRadius="4" Margin="0,10,0,0" Padding="8,6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="◀◀" Command="{Binding 最初の手コマンド}"
                        IsEnabled="{Binding 前の手可能}"
                        Width="36" Margin="2,0" Style="{StaticResource 棋譜ボタン}"/>
                <Button Content="◀"  Command="{Binding 前の手コマンド}"
                        IsEnabled="{Binding 前の手可能}"
                        Width="36" Margin="2,0" Style="{StaticResource 棋譜ボタン}"/>
                <TextBlock Text="{Binding 手数表示}"
                           Foreground="White" FontSize="13" VerticalAlignment="Center"
                           Margin="10,0" MinWidth="90" TextAlignment="Center"/>
                <Button Content="▶"  Command="{Binding 次の手コマンド}"
                        IsEnabled="{Binding 次の手可能}"
                        Width="36" Margin="2,0" Style="{StaticResource 棋譜ボタン}"/>
                <Button Content="▶▶" Command="{Binding 最後の手コマンド}"
                        IsEnabled="{Binding 次の手可能}"
                        Width="36" Margin="2,0" Style="{StaticResource 棋譜ボタン}"/>
                <Button Content="対局に戻る" Command="{Binding 棋譜再生終了コマンド}"
                        Visibility="{Binding 棋譜再生中,
                            Converter={StaticResource BoolToVisibility}}"
                        Margin="12,0,0,0" Style="{StaticResource 棋譜ボタン}"/>
            </StackPanel>
        </Border>
    </Grid>

    </DockPanel>
</Window>
